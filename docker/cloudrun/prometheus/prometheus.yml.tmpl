# Prometheus scrape targets for per-service Cloud Run deployment.

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: llmops_app
    metrics_path: /metrics
    scheme: https
    static_configs:
      - targets:
          - __APP_METRICS_HOST__

  - job_name: llmops_pushgateway
    honor_labels: true
    metrics_path: /metrics
    scheme: https
    static_configs:
      - targets:
          - __PUSHGATEWAY_HOST__
