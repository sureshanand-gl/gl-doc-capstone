# Example local and container environment values for app, LLMOps, and observability services.

OPENAI_API_KEY=
OPENAI_API_BASE=https://aibe.mygreatlearning.com/openai/v1
FIELD_EXTRACTOR_MODE=auto
LLMOPS_PROMPT_VERSION=v2
LLMOPS_SCHEMA_VERSION=v2
LLMOPS_TRACE_TEXT=false
PROMETHEUS_METRICS_PORT=9108
PROMETHEUS_PUSHGATEWAY_URL=http://127.0.0.1:9091
LLMOPS_PRICING_FILE=/app/configs/model_pricing.yaml
EASYOCR_MODEL_DIR=/models/easyocr
QWEN_MODEL_DIR=
GRAFANA_ADMIN_PASSWORD=admin
LAYOUT_WORKER_PYTHON=/app/.venv/bin/python
